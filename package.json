{
  "name": "4amigos",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "next dev",
    "dev:server": "pnpm exec tsx watch packages/server/src/server.ts",
    "dev:all": "concurrently \"pnpm dev\" \"pnpm dev:server\"",
    "build": "next build",
    "build:server": "pnpm --filter @4amigos/server build",
    "start": "next start",
    "start:server": "pnpm --filter @4amigos/server start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "typecheck:server": "pnpm --filter @4amigos/server typecheck"
  },
  "dependencies": {
    "concurrently": "^9.1.2",
    "next": "^16.2.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "socket.io-client": "^4.8.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "tsx": "^4.19.2",
    "@types/node": "^20.19.41",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.2.6",
    "postcss": "^8.5.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.9.3"
  }
}
